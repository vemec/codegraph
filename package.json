{
  "name": "@ashulab/codegraph",
  "version": "0.2.1",
  "description": "Builds a code knowledge graph (multi-language, pluggable connectors) so an agent navigates relationships without grepping everything. TS/JS resolved with the type-checker, MCP server, and an offline Graph Explorer.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "license": "MIT",
  "author": "Diego Ghersi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vemec/codegraph.git"
  },
  "homepage": "https://github.com/vemec/codegraph#readme",
  "bugs": {
    "url": "https://github.com/vemec/codegraph/issues"
  },
  "keywords": [
    "codegraph",
    "knowledge-graph",
    "dependency-graph",
    "call-graph",
    "typescript",
    "javascript",
    "cli",
    "static-analysis"
  ],
  "bin": {
    "codegraph": "lib/cli.js"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "imports": {
    "#src/*": "./src/*.ts"
  },
  "files": [
    "lib",
    "skills",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^20.12 || ^22.12 || ^24.11.1 || ^25.0.0"
  },
  "scripts": {
    "build:explorer": "node scripts/build-explorer.mjs",
    "prebuild": "pnpm build:explorer",
    "predev": "pnpm build:explorer",
    "pretest": "pnpm build:explorer",
    "pretypecheck": "pnpm build:explorer",
    "build": "tsup",
    "prepare": "pnpm build:explorer && pnpm exec tsup",
    "prepublishOnly": "pnpm build && pnpm test",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@sigma/edge-curve": "^3.1.0",
    "@sigma/node-border": "^3.0.0",
    "@types/node": "^25.0.0",
    "esbuild": "^0.25.12",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "sigma": "^3.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
